# Windy Webcams API key — sign up at https://api.windy.com/
# Leave blank to skip Windy as a source.
WINDY_API_KEY=

# ============================================================
# Signup-required sources (6 keys, all free)
# Leave blank to skip that source (project still runs).
# ============================================================

# 511NY — developer signup at https://511ny.org
NY511_API_KEY=

# 511GA — developer signup at https://511ga.org
# Includes real HLS live video (not just snapshots)
GA511_API_KEY=

# 511LA — developer signup at https://511la.org
# (Verify if actually keyless before signing up — same family as Ontario/Alberta)
LA511_API_KEY=

# WSDOT (Washington State DOT) — email signup at wsdot.wa.gov/Traffic/api
# Slowest of the six (~24h human turnaround). Request first.
WSDOT_ACCESS_CODE=

# Hong Kong Transport Dept — register at data.gov.hk
HK_TD_API_KEY=

# Transport for NSW (Australia) — register an app at opendata.transport.nsw.gov.au
NSW_API_KEY=

# ============================================================
# Confirmed keyless — no signup needed, integrated directly
# ============================================================
# Ontario 511 (511on.ca/api/v2/get/cameras) — JSON, Open511
# Alberta 511 (511.alberta.ca/api/v2/get/cameras) — JSON
# MDOT CHART (chart.maryland.gov)
# Germany Autobahn (verkehr.autobahn.de/o/autobahn/{A1..A99}/services/webcam)
# DriveBC — webcam dataset on catalogue.data.gov.bc.ca
#           (api.open511.gov.bc.ca is the EVENTS API, NOT the cameras one)
